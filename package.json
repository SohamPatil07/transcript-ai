{
  "name": "transcript-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "netlify dev",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:build": "vite build",
    "desktop:dist": "vite build && electron-builder --win nsis",
    "extension:prepare": "node scripts/generate-extension-manifest.mjs",
    "extension:dev": "npm run extension:prepare && vite build --watch --config extension/vite.config.mjs",
    "extension:build": "npm run extension:prepare && vite build --config extension/vite.config.mjs",
    "extension:pack": "npm run extension:build"
  },
  "dependencies": {
    "@clerk/backend": "2.10.1",
    "@clerk/clerk-react": "^5.46.1",
    "lucide-react": "^0.468.0",
    "vite": "^5.4.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14"
  },
  "build": {
    "appId": "com.transcriptai.desktop",
    "productName": "Transcript AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
